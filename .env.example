# Required: Gemini AI (free tier at aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Override AI model (default: gemini-2.5-flash-lite)
# GEMINI_MODEL=gemini-2.5-flash-lite

# Required for persistent storage + hourly cron:
# 1. Go to console.upstash.com → Create Redis database (free)
# 2. Copy REST URL and Token from database details page
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here
