{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/ingest.js":    { "maxDuration": 60 },
    "api/brief.js":     { "maxDuration": 30 },
    "api/rss.js":       { "maxDuration": 15 },
    "api/lottery.js":   { "maxDuration": 30 },
    "api/social.js":    { "maxDuration": 30 },
    "api/backfill.js":  { "maxDuration": 60 },
    "api/reddit.js":    { "maxDuration": 30 },
    "api/store-read.js":{ "maxDuration": 15 }
  },
  "crons": [
    {
      "path": "/api/ingest",
      "schedule": "0 * * * *"
    }
  ]
}
